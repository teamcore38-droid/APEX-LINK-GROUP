# Copy this file to `.env` and set environment-specific values.
# Never expose server-side secrets here.
# Optional API base URL if your frontend and backend are hosted separately
VITE_API_URL=
# Optional server-only override used by Vercel SEO functions.
SEO_API_URL=

# Optional environment label (example: development, staging, production)
VITE_APP_ENV=

# Canonical SEO and search engine verification
VITE_SITE_URL=https://www.apexfashion.lk
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=

# Growth / analytics / ad pixels
VITE_GA_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
VITE_TIKTOK_PIXEL_ID=
VITE_LINKEDIN_PARTNER_ID=

# Never add PayHere merchant secrets on frontend.
