# Copy this file to `.env` and set environment-specific values.
# Never expose server-side secrets here.
# Optional API base URL if your frontend and backend are hosted separately
VITE_API_URL=

# Stripe publishable key for live card collection
VITE_STRIPE_PUBLIC_KEY=

# Optional environment label (example: development, staging, production)
VITE_APP_ENV=

# Never add Stripe secret keys on frontend.
