# Copy this file to `.env` and fill real values per environment.
# Never commit real secrets.
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/apexlinkgroup
JWT_SECRET=add_your_secret_here
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
# Optional comma-separated list of extra allowed CORS origins
CORS_ORIGINS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=lkr

# Optional business metadata shown in invoice/packing documents
BUSINESS_NAME=APEX LINK GROUP
BUSINESS_EMAIL=support@apexlinkgroup.com
BUSINESS_PHONE=+1 (555) 123-4567
BUSINESS_ADDRESS=One Apex Plaza, Suite 400, Global Trade District, San Francisco, CA 94110
BUSINESS_WEBSITE=http://localhost:5173

# Email / SMTP
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
