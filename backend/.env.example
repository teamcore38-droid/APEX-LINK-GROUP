# Copy this file to `.env` and fill real values per environment.
# Never commit real secrets.
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/apexlinkgroup
JWT_SECRET=add_your_secret_here
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
# Optional comma-separated list of extra allowed CORS origins
CORS_ORIGINS=

# PayHere
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_CURRENCY=LKR
PAYHERE_SANDBOX=true
# Must be publicly reachable by PayHere. Example: https://abc123.ngrok-free.app/api/payments/payhere/notify
PAYHERE_NOTIFY_URL=
# Used to build PAYHERE_NOTIFY_URL when PAYHERE_NOTIFY_URL is omitted
BACKEND_PUBLIC_URL=

# Cloudinary product image storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PRODUCT_FOLDER=apex-link/products

# Temporary admin 2FA fallback while SMTP is not configured.
# Remove this after EMAIL_* delivery is working.
ADMIN_2FA_BYPASS_CODE=

# Optional business metadata shown in invoice/packing documents
BUSINESS_NAME=Apex Link Import and Export pvt Lmt
BUSINESS_EMAIL=info@apexfashion.lk
BUSINESS_PHONE=+94 76 566 9961
BUSINESS_ADDRESS=580/12, Mosque Lane, Nawala, Rajagiriya, Colombo, Sri Lanka
BUSINESS_WEBSITE=https://apexfashion.lk

# Email / SMTP
# Brevo SMTP values:
#   EMAIL_HOST=smtp-relay.brevo.com
#   EMAIL_PORT=587
#   EMAIL_USER=<your Brevo SMTP login>
#   EMAIL_PASS=<your Brevo SMTP key, not API key>
#   EMAIL_FROM=Apex Fashion <orders@apexfashion.lk>
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_TEST_TO=
EMAIL_SEND_MAX_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=750

# Operations / monitoring
SERVICE_NAME=apex-backend
SENTRY_DSN=
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
UPTIME_URLS=
UPTIME_TIMEOUT_MS=8000

# Backups / performance
DB_BACKUP_DIR=./backups
ALLOW_DB_RESTORE=false
LOAD_TEST_BASE_URL=http://127.0.0.1:5000
LOAD_TEST_REQUESTS=50
LOAD_TEST_CONCURRENCY=10

# Growth / marketing
NEWSLETTER_WEBHOOK_URL=
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=
DEFAULT_CURRENCY=LKR
INDEXNOW_ENABLED=true
INDEXNOW_KEY=1ef018ac3d1ac76bbd2ec0b7d79ce2ce
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
ABANDONED_CART_SEND_LIMIT=50
ABANDONED_CART_MIN_AGE_MINUTES=60
